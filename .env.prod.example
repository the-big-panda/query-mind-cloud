# Production Environment Configuration
# Copy this file to .env and update with your production values

# ============================================
# CRITICAL: CHANGE THESE VALUES IN PRODUCTION
# ============================================

# Generate secure JWT secret
JWT_SECRET=your-production-secret-key-32-chars-min

# Database credentials (MUST match across services)
DB_PASSWORD=your-strong-database-password

# Redis password
REDIS_PASSWORD=your-redis-password

# ============================================
# ENVIRONMENT SETTINGS
# ============================================

NODE_ENV=production
LOG_LEVEL=info

# ============================================
# SERVICE CONFIGURATION
# ============================================

# Cloud Backend
PORT=3000
JWT_EXPIRY=24h

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nl2sql_backend
DB_USER=postgres
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# CORS & API SETTINGS
# ============================================

# Update with your production domain
CORS_ORIGIN=https://app.yourdomain.com,https://api.yourdomain.com

# ============================================
# KUBERNETES CONFIGURATION
# ============================================

K8S_NAMESPACE=default
K8S_SERVICE_ACCOUNT=cloud-backend
K8S_CONTAINER_IMAGE=you-registry.azurecr.io/nl2sql-worker:1.0.0
K8S_CONTAINER_PORT=8080
K8S_CPU_REQUEST=500m
K8S_CPU_LIMIT=2000m
K8S_MEMORY_REQUEST=512Mi
K8S_MEMORY_LIMIT=2Gi
K8S_CONTAINER_REGISTRY=you-registry.azurecr.io

# ============================================
# SERVICE INTEGRATION
# ============================================

BE_PROJECT_URL=http://be-project:8080
BE_PROJECT_WS_URL=ws://be-project:8080

# ============================================
# CONTAINER MANAGEMENT
# ============================================

CONTAINER_IDLE_TIMEOUT=3600000
CONTAINER_CHECK_INTERVAL=60000
MAX_CONTAINERS_PER_USER=1

# ============================================
# MONITORING & LOGGING
# ============================================

# Application logging level: error, warn, info, debug
LOG_LEVEL=info

# Enable performance monitoring
ENABLE_METRICS=true

# ============================================
# SECURITY HEADERS
# ============================================

# Set to your domain for production
SECURITY_HEADERS_ENABLED=true
