# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# JWT Configuration (MUST match BE-Project JWT_SECRET for integration)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRY=24h

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nl2sql_backend
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kubernetes Configuration
K8S_NAMESPACE=default
K8S_SERVICE_ACCOUNT=cloud-backend
K8S_CONTAINER_IMAGE=nl2sql-worker:latest
K8S_CONTAINER_PORT=8080
K8S_CPU_REQUEST=500m
K8S_CPU_LIMIT=2000m
K8S_MEMORY_REQUEST=512Mi
K8S_MEMORY_LIMIT=2Gi
K8S_CONTAINER_REGISTRY=localhost:5000

# Container Management
CONTAINER_IDLE_TIMEOUT=3600000
CONTAINER_CHECK_INTERVAL=60000
MAX_CONTAINERS_PER_USER=1

# CORS Configuration (allow BE-Project and frontend)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:8000,*

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=5000
WS_MAX_CONNECTIONS=1000

# BE-Project Integration
BE_PROJECT_URL=http://localhost:8080
BE_PROJECT_WS_URL=ws://localhost:8080

