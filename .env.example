# ================================================================================
# CLOUD BACKEND - AUTHENTICATION & CONTAINER MANAGEMENT ONLY
# ================================================================================
# Architecture:
#   - BE-Project (Local) → Stores conversations/messages locally
#   - Cloud Backend (Container) → Authenticates users + manages their AI containers
#   - Ollama (Container) → LLM inference backend
#   - AI Server (Container) → NL2SQL service wrapper
#   - PostgreSQL (Native on EC2) → For cloud-backend user/session data
#   - Redis (Native on EC2) → For caching/session management
#
# Cloud-backend responsibilities:
#   ✅ Verify/authenticate users (JWT validation)
#   ✅ Track user sessions
#   ✅ Create/manage per-user AI server containers
#   ✅ Route users to their respective containers
#   ❌ Does NOT store conversations (BE-Project handles that)
#   ❌ Does NOT query user data (BE-Project owns that)
# ================================================================================

# Server Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# JWT Configuration (MUST match BE-Project JWT_SECRET)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRY=24h

# AI Server Configuration (NL2SQL LLM Service)
AI_SERVER_URL=http://ai-server:9001
AI_SERVER_IMAGE_REGISTRY=docker.io
AI_SERVER_IMAGE_NAME=yourusername/nl2sql-ai-server
AI_SERVER_IMAGE_TAG=latest

# Ollama Configuration (LLM Inference Engine)
OLLAMA_URL=http://ollama:11434/api/generate

# CORS Configuration (for BE-Project integration)
CORS_ORIGIN=http://localhost:8080

# Kubernetes Configuration
K8S_NAMESPACE=default
AI_SERVER_IMAGE_REGISTRY=docker.io
AI_SERVER_IMAGE_NAME=yourusername/nl2sql-ai-server
AI_SERVER_IMAGE_TAG=latest
AI_SERVER_IMAGE=docker.io/yourusername/nl2sql-ai-server:latest
OLLAMA_URL=http://ollama:11434/api/generate
K8S_CPU_REQUEST=500m
K8S_CPU_LIMIT=2000m
K8S_MEMORY_REQUEST=512Mi
K8S_MEMORY_LIMIT=2Gi
K8S_CONTAINER_REGISTRY=localhost:5000

# Container Management
CONTAINER_IDLE_TIMEOUT=3600000
CONTAINER_CHECK_INTERVAL=60000
MAX_CONTAINERS_PER_USER=1

# CORS Configuration (allow BE-Project and frontend)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:8000,*

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=5000
WS_MAX_CONNECTIONS=1000

# BE-Project Integration
BE_PROJECT_URL=http://localhost:8080
BE_PROJECT_WS_URL=ws://localhost:8080

